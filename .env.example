# MiniCode local configuration example.
# Copy this file to .env and replace placeholder values locally.
# Do not commit .env or real API keys.

# LLM provider: openai or anthropic
LLM_PROVIDER=openai

# OpenAI or OpenAI-compatible endpoint
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic, used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514

# Workspace and mode defaults
WORKSPACE_PATH=.
AGENT_MODE=agent
MAX_ITERATIONS=30
LOG_LEVEL=INFO
CONTEXT_MAX_TOKENS=120000

# Local baseline: keep optional external features disabled first.
# Use CLI --no-memory for first smoke runs because the CLI currently
# enables project memory from its command-line flag, not this variable.
MEMORY_ENABLED=false
INTENT_AUDITOR_ENABLED=false
AUDITOR_TWO_LAYER=false

# Optional embedding service for two-layer Intent Auditor.
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v3
EMBED_API_KEY=your-embedding-api-key
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
